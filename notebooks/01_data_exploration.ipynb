import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Load raw data (Example: stocks or ETF data)
data = pd.read_csv('data/raw/sample_market_data.csv')

# Display the first few rows to inspect the data
print(data.head())

# Check for missing values
print(data.isnull().sum())

# Calculate daily returns
data['Asset_A_return'] = data['Asset_A'].pct_change()
data['Asset_B_return'] = data['Asset_B'].pct_change()

# Visualize the returns distribution
sns.histplot(data['Asset_A_return'], kde=True, color="blue", label="Asset_A")
sns.histplot(data['Asset_B_return'], kde=True, color="red", label="Asset_B")
plt.legend()
plt.title('Returns Distribution of Assets')
plt.show()

# Correlation heatmap for returns
sns.heatmap(data[['Asset_A_return', 'Asset_B_return']].corr(), annot=True, cmap='coolwarm')
plt.title('Correlation Between Assets')
plt.show()